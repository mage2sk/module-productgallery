 * Alpine.js + Tailwind CSS
 *
 * @var \Panth\ProductGallery\Block\Gallery $block
 * @var \Magento\Framework\Escaper $escaper
 */

/** @var \Panth\ProductGallery\ViewModel\Config|null $viewModel */
/** @var array|null $images */
/** @var array|null $config */

// Read from block data (set by plugin)
$viewModel = $block->getData('panth_gallery_viewmodel') ?: $block->getData('view_model');
if (!$viewModel instanceof \Panth\ProductGallery\ViewModel\Config) {
    return;
}
$images = $block->getData('panth_gallery_images');
if (empty($images) && method_exists($block, 'getGalleryImages')) {
    $images = $block->getGalleryImages();
}
if (empty($images)) {
    return;
}
$config = $block->getData('panth_gallery_config') ?: $viewModel->getGalleryConfig();
$layoutType = $config['layout_type'] ?? 'horizontal';
$thumbPosition = 'bottom';
$enableZoom = (bool) ($config['enable_zoom'] ?? true);
$zoomLevel = (int) ($config['zoom_level'] ?? 3);
$enableLightbox = (bool) ($config['enable_lightbox'] ?? true);
$showCounter = (bool) ($config['show_counter'] ?? true);
$enableKeyboardNav = (bool) ($config['enable_keyboard_nav'] ?? true);
$showArrows = (bool) ($config['show_arrows'] ?? true);
$infiniteLoop = (bool) ($config['infinite_loop'] ?? false);
$thumbWidth = 72;
$thumbHeight = 72;

$galleryId = 'panth-gallery-' . uniqid();

$imagesJson = $escaper->escapeHtmlAttr(json_encode(array_map(function ($img) {
    return [
        'thumb' => $img['thumb'],
        'medium' => $img['medium'],
        'large' => $img['large'],
        'alt' => $img['alt'],
    ];
}, $images)));

// Layout classes
$wrapperClass = 'panth-gallery';
if ($layoutType === 'vertical') {
    $wrapperClass .= ' flex gap-4';
}
?>

<div class="<?= $escaper->escapeHtmlAttr($wrapperClass) ?>"
     id="<?= $escaper->escapeHtmlAttr($galleryId) ?>"
     x-data="panthGallery()"
     x-init="init(<?= /* @noEscape */ $imagesJson ?>)"
     <?php if ($enableKeyboardNav): ?>
     @keydown.escape.window="closeLightbox()"
     @keydown.arrow-left.window="lightboxOpen && lightboxPrev()"
     @keydown.arrow-right.window="lightboxOpen && lightboxNext()"
     <?php endif; ?>
>
    <?php if ($layoutType === 'grid'): ?>
        <!-- Grid Layout -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
            <?php foreach ($images as $index => $image): ?>
                <div class="<?= $index === 0 ? 'col-span-2 md:col-span-2 row-span-2' : '' ?> overflow-hidden rounded-lg cursor-pointer border border-gray-200"
                     @click="<?= $enableLightbox ? 'openLightbox(' . (int) $index . ')' : '' ?>">
                    <img src="<?= $escaper->escapeUrl($image['medium']) ?>"
                         alt="<?= $escaper->escapeHtmlAttr($image['alt']) ?>"
                         class="w-full h-full object-contain bg-gray-50 transition-transform duration-300 hover:scale-105"
                         loading="<?= $index === 0 ? 'eager' : 'lazy' ?>" />
                </div>
            <?php endforeach; ?>
        </div>
    <?php else: ?>
        <?php $isVertical = ($layoutType === 'vertical'); ?>

        <?php if ($isVertical && count($images) > 1): ?>
            <!-- Vertical Thumbnails (Left) -->
            <div style="display:flex;flex-direction:column;gap:8px;overflow-y:auto;max-height:500px;width:<?= $thumbWidth + 20 ?>px;">
                <?php foreach ($images as $index => $image): ?>
                    <button type="button"
                            style="flex-shrink:0;border-radius:8px;overflow:hidden;transition:all 0.2s;cursor:pointer;background:#fff;padding:3px;"
                            :style="currentIndex === <?= (int) $index ?> ? 'border:2px solid var(--color-primary, #0D9488);box-shadow:0 0 0 2px rgba(13,148,136,0.2);' : 'border:2px solid #9CA3AF;'"
                            @click="goToImage(<?= (int) $index ?>)"
                            aria-label="<?= $escaper->escapeHtmlAttr(__('View image %1', $index + 1)) ?>">
                        <img src="<?= $escaper->escapeUrl($image['thumb']) ?>"
                             alt="<?= $escaper->escapeHtmlAttr($image['alt']) ?>"
                             width="<?= $escaper->escapeHtmlAttr((string) $thumbWidth) ?>"
                             height="<?= $escaper->escapeHtmlAttr((string) $thumbHeight) ?>"
                             style="object-fit:contain;background:#F9FAFB;"
                             loading="lazy" />
                    </button>
                <?php endforeach; ?>
            </div>
        <?php endif; ?>

        <!-- Main Image -->
        <div style="flex:1;position:relative;" id="gallery">
            <div style="position:relative;overflow:hidden;border-radius:8px;border:1px solid #E5E7EB;background:#F9FAFB;" class="product-image-wrapper"
                 <?php if ($enableZoom): ?>
                 @mousemove="handleZoom($event)"
                 @mouseleave="zoomActive = false"
                 <?php endif; ?>
            >
                <img :src="images[currentIndex]?.medium"
                     alt="Product image"
                     :alt="images[currentIndex]?.alt"
                     style="width:100%;height:auto;object-fit:contain;transition:opacity 0.2s;<?= $enableLightbox ? 'cursor:pointer;' : '' ?>"
                     <?php if ($enableLightbox): ?>
                     @click="openLightbox(currentIndex)"
                     <?php endif; ?>
                     loading="eager" />

                <?php if ($enableZoom): ?>
                    <div x-show="zoomActive"
                         style="position:absolute;top:0;left:0;right:0;bottom:0;pointer-events:none;overflow:hidden;z-index:5;">
                        <div :style="zoomStyle"
                             style="position:absolute;top:0;left:0;right:0;bottom:0;background-repeat:no-repeat;">
                        </div>
                    </div>
                <?php endif; ?>

                <?php if ($showArrows && count($images) > 1): ?>
                    <button type="button"
                            style="position:absolute;left:8px;top:50%;transform:translateY(-50%);width:40px;height:40px;border-radius:50%;background:rgba(0,0,0,0.4);border:none;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:10;transition:background 0.2s;"
                            onmouseenter="this.style.background='rgba(0,0,0,0.7)'"
                            onmouseleave="this.style.background='rgba(0,0,0,0.4)'"
                            @click="prevImage()"
                            aria-label="<?= $escaper->escapeHtmlAttr(__('Previous image')) ?>">
                        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                        </svg>
                    </button>
                    <button type="button"
                            style="position:absolute;right:8px;top:50%;transform:translateY(-50%);width:40px;height:40px;border-radius:50%;background:rgba(0,0,0,0.4);border:none;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:10;transition:background 0.2s;"
                            onmouseenter="this.style.background='rgba(0,0,0,0.7)'"
                            onmouseleave="this.style.background='rgba(0,0,0,0.4)'"
                            @click="nextImage()"
                            aria-label="<?= $escaper->escapeHtmlAttr(__('Next image')) ?>">
                        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </button>
                <?php endif; ?>
            </div>
        </div>


        <?php if (!$isVertical && count($images) > 1): ?>
            <!-- Horizontal Thumbnails (Bottom) -->
            <div style="display:flex;gap:8px;margin-top:12px;overflow-x:auto;padding-bottom:8px;">
                <?php foreach ($images as $index => $image): ?>
                    <button type="button"
                            style="flex-shrink:0;border-radius:8px;overflow:hidden;transition:all 0.2s;cursor:pointer;background:#fff;padding:3px;"
                            :style="currentIndex === <?= (int) $index ?> ? 'border:2px solid var(--color-primary, #0D9488);box-shadow:0 0 0 2px rgba(13,148,136,0.2);' : 'border:2px solid #9CA3AF;'"
                            @click="goToImage(<?= (int) $index ?>)"
                            aria-label="<?= $escaper->escapeHtmlAttr(__('View image %1', $index + 1)) ?>">
                        <img src="<?= $escaper->escapeUrl($image['thumb']) ?>"
                             alt="<?= $escaper->escapeHtmlAttr($image['alt']) ?>"
                             width="<?= $escaper->escapeHtmlAttr((string) $thumbWidth) ?>"
                             height="<?= $escaper->escapeHtmlAttr((string) $thumbHeight) ?>"
                             style="object-fit:contain;background:#F9FAFB;"
                             loading="lazy" />
                    </button>
                <?php endforeach; ?>
            </div>
        <?php endif; ?>
    <?php endif; ?>

</div>

<script>
    function panthGallery() {
        return {
            images: [],
            currentIndex: 0,
            zoomActive: false,
            zoomStyle: '',
            infiniteLoop: <?= $infiniteLoop ? 'true' : 'false' ?>,

            init(imageData) {
                this.images = imageData;
            },

            goToImage(index) {
                if (index >= 0 && index < this.images.length) {
                    this.currentIndex = index;
                }
            },

            prevImage() {
                if (this.infiniteLoop) {
                    this.currentIndex = this.currentIndex <= 0 ? this.images.length - 1 : this.currentIndex - 1;
                } else {
                    this.currentIndex = Math.max(0, this.currentIndex - 1);
                }
            },

            nextImage() {
                if (this.infiniteLoop) {
                    this.currentIndex = this.currentIndex >= this.images.length - 1 ? 0 : this.currentIndex + 1;
                } else {
                    this.currentIndex = Math.min(this.images.length - 1, this.currentIndex + 1);
                }
            },

            <?php if ($enableZoom): ?>
            handleZoom(event) {
                var rect = event.currentTarget.getBoundingClientRect();
                var xPct = ((event.clientX - rect.left) / rect.width) * 100;
                var yPct = ((event.clientY - rect.top) / rect.height) * 100;

                this.zoomActive = true;
                this.zoomStyle = 'position:absolute;top:0;left:0;right:0;bottom:0;background-repeat:no-repeat;' +
                    'background-image:url(' + this.images[this.currentIndex].large + ');' +
                    'background-size:<?= (int) $zoomLevel * 100 ?>%;' +
                    'background-position:' + xPct + '% ' + yPct + '%;';
            },
            <?php endif; ?>

            <?php if ($enableLightbox): ?>
            openLightbox(index) {
                window.panthLightbox.open(this.images, index);
            },

            closeLightbox() {},
            <?php endif; ?>
        };
    }

    <?php if ($enableLightbox): ?>
    (function() {
        var lb = null, img = null, counter = null, idx = 0, imgs = [], zoom = 1;

        function create() {
            lb = document.createElement('div');
            lb.id = 'panth-lightbox-overlay';
            lb.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:999999;display:none;align-items:center;justify-content:center;background:rgba(0,0,0,0.93);';

            <?php if ($showCounter): ?>
            counter = document.createElement('div');
            counter.style.cssText = 'position:fixed;top:20px;left:20px;color:rgba(255,255,255,0.85);font-size:14px;font-weight:600;z-index:999999;';
            lb.appendChild(counter);
            <?php endif; ?>

            // Top-right controls: zoom in, zoom out, close
            var controls = document.createElement('div');
            controls.style.cssText = 'position:fixed;top:16px;right:16px;z-index:999999;display:flex;gap:8px;';

            var zoomInBtn = makeBtn('relative', '', '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v6m3-3H7"/></svg>');
            zoomInBtn.onclick = function(e) { e.stopPropagation(); zoomIn(); };
            controls.appendChild(zoomInBtn);

            var zoomOutBtn = makeBtn('relative', '', '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM13 10H7"/></svg>');
            zoomOutBtn.onclick = function(e) { e.stopPropagation(); zoomOut(); };
            controls.appendChild(zoomOutBtn);

            var closeBtn = makeBtn('relative', '', '<svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>');
            closeBtn.onclick = function(e) { e.stopPropagation(); close(); };
            controls.appendChild(closeBtn);

            lb.appendChild(controls);

            var prevBtn = makeBtn('fixed', 'left:16px;top:50%;transform:translateY(-50%);', '<svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>');
            prevBtn.onclick = function(e) { e.stopPropagation(); prev(); };
            lb.appendChild(prevBtn);

            var nextBtn = makeBtn('fixed', 'right:16px;top:50%;transform:translateY(-50%);', '<svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>');
            nextBtn.onclick = function(e) { e.stopPropagation(); next(); };
            lb.appendChild(nextBtn);

            img = document.createElement('img');
            img.style.cssText = 'max-width:85vw;max-height:85vh;object-fit:contain;position:relative;z-index:1;transition:transform 0.3s ease;cursor:grab;';
            img.draggable = false;
            lb.appendChild(img);

            lb.addEventListener('click', function(e) { if (e.target === lb) close(); });

            // Mouse wheel zoom
            lb.addEventListener('wheel', function(e) {
                e.preventDefault();
                if (e.deltaY < 0) zoomIn(); else zoomOut();
            }, { passive: false });

            <?php if ($enableKeyboardNav): ?>
            document.addEventListener('keydown', function(e) {
                if (lb.style.display !== 'flex') return;
                if (e.key === 'Escape') close();
                if (e.key === 'ArrowLeft') prev();
                if (e.key === 'ArrowRight') next();
                if (e.key === '+' || e.key === '=') zoomIn();
                if (e.key === '-') zoomOut();
                if (e.key === '0') resetZoom();
            });
            <?php endif; ?>

            document.body.appendChild(lb);
        }

        function makeBtn(pos, extra, svg) {
            var b = document.createElement('button');
            b.type = 'button';
            b.style.cssText = 'position:' + pos + ';' + extra + 'z-index:999999;width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,0.15);border:none;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.2s;';
            b.innerHTML = svg;
            b.onmouseenter = function() { b.style.background = 'rgba(255,255,255,0.3)'; };
            b.onmouseleave = function() { b.style.background = 'rgba(255,255,255,0.15)'; };
            return b;
        }

        function applyZoom() {
            if (img) img.style.transform = 'scale(' + zoom + ')';
        }

        function zoomIn() { zoom = Math.min(5, zoom + 0.5); applyZoom(); }
        function zoomOut() { zoom = Math.max(0.5, zoom - 0.5); applyZoom(); }
        function resetZoom() { zoom = 1; applyZoom(); }

        function update() {
            img.src = imgs[idx].large;
            img.alt = imgs[idx].alt;
            resetZoom();
            if (counter) counter.textContent = (idx + 1) + ' / ' + imgs.length;
        }

        function open(images, index) {
            if (!lb) create();
            imgs = images; idx = index;
            update();
            lb.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        function close() {
            if (lb) lb.style.display = 'none';
            document.body.style.overflow = '';
            resetZoom();
        }

        function prev() { idx = idx <= 0 ? imgs.length - 1 : idx - 1; update(); }
        function next() { idx = idx >= imgs.length - 1 ? 0 : idx + 1; update(); }

        window.panthLightbox = { open: open, close: close };
    })();
    <?php endif; ?>
</script>
