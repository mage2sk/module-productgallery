<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Panth\Core\ViewModel\ThemeConfig">
        <arguments>
            <argument name="registeredModules" xsi:type="array">
                <item name="Panth_ProductGallery" xsi:type="string">Panth_ProductGallery</item>
            </argument>
        </arguments>
    </type>

    <!-- Hide default Magento/Hyva gallery when Panth gallery is enabled -->
    <type name="Magento\Catalog\Block\Product\View\Gallery">
        <plugin name="panth_hide_default_gallery"
                type="Panth\ProductGallery\Plugin\HideDefaultGallery"
                sortOrder="10"/>
    </type>
</config>
